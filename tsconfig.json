{
  "compilerOptions": {
    "allowJs": true,
    // "checkJs": true, 
    "target": "ES2017",
    "jsx": "preserve",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "types",
    "skipLibCheck": true,
    "noEmitOnError": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "components/*"
      ]
    },
    "types": [
      "vue",
      // "@types/vue"
    ]
  },
  "include": [
    "components/**/*.jsx",
    // "components/**/*.js", 
    // "components/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}