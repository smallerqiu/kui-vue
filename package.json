{
  "name": "kui-vue-4.x",
  "version": "4.0.0",
  "description": "A lightweight desktop UI component library suitable for Vue 3.",
  "main": "dist/k-ui.js",
  "module": "dist/k-ui.esm.js",
  "unpkg": "dist/k-ui.min.js",
  "jsdelivr": "dist/k-ui.min.js",
  "author": "Qiu",
  "license": "MIT",
  "typings": "dist/k-ui.d.ts",
  "homepage": "https://k-ui.cn/",
  "bugs": {
    "url": "https://gitee.com/chuchur/kui-vue/issues"
  },
  "keywords": [
    "vue",
    "kui",
    "kui-vue"
  ],
  "scripts": {
    "start": "npm run serve",
    "serve": "vue-cli-service serve",
    "build": "npm",
    "build:es": "npm",
    "build:umd": "npm",
    "build:docs": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "build:types": "tsc --emitDeclarationOnly",
    "build:css": "lessc --clean-css='--s1 --advanced --compat' components/styles/index.less dist/k-ui.css && postcss -u autoprefixer -b '> 1%, not ie 11,not dead' dist/k-ui.css -o dist/k-ui.css --no-map"
  },
  "dependencies": {
    "color": "^5.0.0",
    "kui-icons": "^4.1.5",
    "vue": "^3.4.38"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/babel-plugin-jsx": "^1.4.0",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "@vueuse/core": "^13.0.0",
    "babel-eslint": "^10.1.0",
    "core-js": "^3.8.3",
    "dayjs": "^1.11.13",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.7.1",
    "less-loader": "^12.2.0",
    "lodash.assign": "^4.2.0",
    "lodash.clonedeep": "^4.5.0",
    "lodash.pick": "^4.4.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "vue-router": "^4.4.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
