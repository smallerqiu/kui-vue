{
  "name": "kui-vue",
  "private": false,
  "version": "5.0.0",
  "description": "A lightweight desktop UI component library suitable for Vue.js 3.",
  "main": "dist/k-ui.js",
  "module": "dist/k-ui.mjs",
  "unpkg": "dist/k-ui.umd.js",
  "jsdelivr": "dist/k-ui.umd.js",
  "style": "dist/k-ui.css",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/k-ui.mjs",
      "module": "./dist/k-ui.mjs",
      "require": "./dist/k-ui.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "test",
    "types",
    "components/"
  ],
  "license": "MIT",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "vite build",
    "build:docs": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "format": "prettier --write .",
    "format:md": "prettier --write ./components/*/index.md",
    "tsc": "vue-tsc --build --declaration --emitDeclarationOnly",
    "type-check": "vue-tsc --build --noEmit"
  },
  "author": {
    "name": "Qiu",
    "email": "smallerqiu@gmail.com"
  },
  "homepage": "https://k-ui.cn",
  "repository": {
    "type": "git",
    "url": "https://github.com/smallerqiu/kui-vue"
  },
  "bugs": {
    "url": "https://github.com/smallerqiu/kui-vue/issues",
    "email": "smallerqiu@gmail.com"
  },
  "keywords": [
    "vue",
    "vue3",
    "kui",
    "kui-vue",
    "kyui",
    "design",
    "kui-vue",
    "vueComponent",
    "ui",
    "ui-library",
    "vue3-components",
    "ui-kit"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "big.js": "^7.0.1",
    "color": "^5.0.3",
    "dayjs": "^1.11.20",
    "kui-icons": "^4.3.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "fast-glob": "^3.3.3",
    "highlight.js": "^11.11.1",
    "less": "^4.6.4",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6"
  }
}
