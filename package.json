{
  "name": "kui-vue",
  "private": false,
  "version": "5.0.0",
  "type": "module",
  "description": "A lightweight desktop UI component library suitable for Vue.js 3.",
  "main": "lib/index.js",
  "module": "es/index.js",
  "unpkg": "dist/index.js",
  "jsdelivr": "dist/index.js",
  "style": "style/index.css",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./dist/*": "./dist/*",
    "./global": {
      "types": "./dist/global.d.ts"
    },
    "./locale/*": {
      "types": "./types/locale/*.d.ts",
      "import": "./es/locale/*.js",
      "require": "./lib/locale/*.js"
    },
    "./style/*": "./style/*"
  },
  "files": [
    "dist",
    "test",
    "vetur",
    "lib",
    "styles",
    "es"
  ],
  "license": "MIT",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite --config vite.config.docs.ts",
    "build": "npm run build:css && npm run build:lib && npm run build:umd && npm run build:es",
    "build:es": "vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:umd": "vite build --config vite.config.umd.ts",
    "build:css": "vite build --config vite.config.css.ts",
    "build:docs": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "format": "prettier --write .",
    "format:md": "prettier --write ./components/*/index*.md",
    "tsc": "vue-tsc --build --declaration --emitDeclarationOnly",
    "type-check": "vue-tsc --build --noEmit"
  },
  "author": {
    "name": "Qiu",
    "email": "smallerqiu@gmail.com"
  },
  "homepage": "https://k-ui.cn",
  "repository": {
    "type": "git",
    "url": "https://github.com/smallerqiu/kui-vue"
  },
  "bugs": {
    "url": "https://github.com/smallerqiu/kui-vue/issues",
    "email": "smallerqiu@gmail.com"
  },
  "keywords": [
    "vue",
    "vue3",
    "kui",
    "kui-vue",
    "kyui",
    "design",
    "kui-vue",
    "vueComponent",
    "ui",
    "ui-library",
    "vue3-components",
    "ui-kit"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "big.js": "^7.0.1",
    "color": "^5.0.3",
    "dayjs": "^1.11.20",
    "kui-icons": "^4.3.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/big.js": "^6.2.2",
    "@types/hash-sum": "^1.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/compiler-sfc": "^3.5.32",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "fast-glob": "^3.3.3",
    "hash-sum": "^2.0.0",
    "highlight.js": "^11.11.1",
    "js-beautify": "^1.15.4",
    "less": "^4.6.4",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "prettier": "^3.8.3",
    "ts-morph": "^27.0.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6"
  },
  "vetur": {
    "tags": "vetur/tags.json",
    "attributes": "vetur/attributes.json"
  },
  "web-types": "./vetur/web-types.json"
}
