{
  "name": "kui-vue",
  "private": false,
  "version": "4.0.0",
  "description": "A lightweight desktop UI component library suitable for Vue.js 3.",
  "type": "module",
  "main": "dist/k-ui.cjs.js",
  "module": "dist/k-ui.esm.js",
  "unpkg": "dist/k-ui.umd.js",
  "jsdelivr": "dist/k-ui.umd.js",
  "style": "dist/k-ui.css",
  "types": "dist/k-ui.d.ts",
  "files": [
    "dist",
    "test",
    "types",
    "components/"
  ],
  "license": "MIT",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build:docs": "vite build",
    "build": "npm run build:types && rollup -c --bundleConfigAsCjs",
    "build:types": "node scripts/gen-dts.js",
    "preview": "vite preview",
    "format": "prettier --write ."
  },
  "author": {
    "name": "Qiu",
    "email": "smallerqiu@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/chuchur/kui-vue"
  },
  "bugs": {
    "url": "https://gitee.com/chuchur/kui-vue/issues",
    "email": "smallerqiu@gmail.com"
  },
  "keywords": [
    "vue",
    "vue3",
    "kui",
    "kyui",
    "design",
    "kui-vue",
    "vueComponent",
    "component",
    "components",
    "ui",
    "framework",
    "frontend"
  ],
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "color": "^5.0.3",
    "dayjs": "^1.11.19",
    "kui-icons": "^4.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "@vue/babel-preset-jsx": "^1.4.0",
    "@vue/compiler-sfc": "3.5.27",
    "@vueuse/core": "^14.2.0",
