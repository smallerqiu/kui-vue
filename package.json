    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-vue": "^6.0.0",
    "vite": "npm:rolldown-vite@7.3.1",
    "vue-router": "^5.0.2"
  },
