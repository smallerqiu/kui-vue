{
  "name": "kui-vue",
  "version": "3.4.9",
  "description": "A lightweight desktop UI component library suitable for Vue.js 2.",
  "private": false,
  "main": "dist/k-ui.js",
  "style": "dist/k-ui.css",
  "files": [
    "dist",
    "test",
    "components/",
    "typings/global.d.ts"
  ],
  "scripts": {
    "start": "npm run serve",
    "serve": "vue-cli-service serve",
    "build:docs": "vue-cli-service build --dest docs",
    "build:lib": "vue-cli-service build --progres --no-clean --target lib --name k-ui components/index.js && rm -rf dist/demo.html",
    "build:lang": "vue-cli-service build --progres --dest dist/locale --target lib --name lang --formats umd-min components/locale/index.js",
    "build:css": "lessc --plugin='less-plugin-clean-css' components/styles/index.less dist/k-ui.css && postcss -u autoprefixer -b '> 1%, not ie 11,not dead' dist/k-ui.css -o dist/k-ui.css --no-map",
    "lint": "vue-cli-service lint"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/chuchur/kui-vue"
  },
  "author": {
    "name": "Qiu",
    "email": "smallerqiu@gmail.com"
  },
  "license": "ISC",
  "keywords": [
    "vue",
    "vue3",
    "kui",
    "kyui",
    "design",
    "kui-vue",
    "vueComponent",
    "component",
    "components",
    "ui",
    "framework",
    "frontend"
  ],
  "homepage": "https://k-ui.cn",
  "bugs": {
    "url": "https://gitee.com/chuchur/kui-vue/issues",
    "email": "smallerqiu@gmail.com"
  },
  "dependencies": {
    "clean-webpack-plugin": "^4.0.0",
    "dayjs": "^1.11.8",
    "kui-icons": "^4.1.3",
    "kui-loader": "^1.0.6",
    "lodash.assign": "^4.2.0",
    "lodash.pick": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/babel-helper-vue-jsx-merge-props": "^1.4.0",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "babel-loader": "^10.0.0",
    "core-js": "^3.8.3",
    "css-loader": "^7.1.2",
    "deepmerge": "^4.3.1",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "file-loader": "^6.2.0",
    "less": "^4.2.0",
    "less-loader": "^11.1.3",
    "less-plugin-clean-css": "^1.6.0",
    "lodash": "^4.17.21",
    "lodash.clonedeep": "^4.5.0",
    "markdown-it": "^13.0.1",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-container": "^3.0.0",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.4",
    "postcss-cli": "^11.0.1",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.10",
    "vue": "^2.7.16",
    "vue-clipboard2": "^0.3.3",
    "vue-i18n": "^8.28.2",
    "vue-loader": "^15.11.1",
    "vue-router": "^3.6.5",
    "vue-style-loader": "^4.1.3",
    "vue-template-compiler": "^2.7.16",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^6.0.1",
    "webpackbar": "^6.0.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 3 versions",
    "not dead"
  ]
}