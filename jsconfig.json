{
  "compilerOptions": {
    "target": "esnext",             // 语法目标（用于语法检查）
    "module": "esnext",             // 模块系统类型
    "checkJs": true,                // 启用 JS 类型检查
    "baseUrl": ".",                 // 基础路径（一般为项目根目录）
    "paths": {                      // 路径别名（支持通配符 *）
      "@/*": ["src/*"],
      "components/*": ["src/components/*"]
    },
    "jsx": "preserve"               // 启用 JSX 支持（配合 Vue 2 JSX 或 React）
  },
  "include": ["src/**/*"],          // 包含的文件
  "exclude": ["node_modules", "dist"]
}